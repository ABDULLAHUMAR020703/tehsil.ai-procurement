NODE_ENV=development
PORT=4000

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Amount threshold for adding GM stage to approvals
HIGH_VALUE_THRESHOLD=100000

# Supabase Storage bucket for PR documents (create this bucket in Supabase)
SUPABASE_STORAGE_BUCKET_DOCUMENTS=pr-documents

# Comma-separated frontend origins (required in production for Vercel)
# CORS_ORIGIN=http://localhost:3000,https://tehsil-ai-procurement.vercel.app

# Set to 1 to include Supabase/Postgres error codes in 500 JSON responses
# EXPOSE_API_ERRORS=1

# Verbose PO upload stage logs when pino request logger is unavailable
# PO_UPLOAD_DEBUG=1

